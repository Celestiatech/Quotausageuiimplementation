{
  "name": "careerpilot-indeed-extension",
  "version": "1.1.3",
  "private": true,
  "description": "Local Playwright tests for AutoApply CV Indeed extension.",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:live:indeed:dry": "CP_REAL_INDEED_TEST=1 playwright test tests/live-indeed-smoke.spec.js --headed",
    "test:smartapply": "CP_REAL_INDEED_TEST=1 playwright test tests/smartapply-real-world.spec.js --headed",
    "test:full": "CP_REAL_INDEED_TEST=1 playwright test tests/indeed-smartapply-full.spec.js --headed",
    "test:full:headless": "CP_REAL_INDEED_TEST=1 playwright test tests/indeed-smartapply-full.spec.js",
    "test:report": "playwright show-report",
    "test:helper": "./run-tests.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2"
  }
}
